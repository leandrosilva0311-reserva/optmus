# App
APP_NAME=optimus
APP_ENV=development
APP_PORT=8000

# Security/Auth
SECRET_KEY=change-me
AUTH_ENABLED=true
AUTH_SESSION_TTL_SECONDS=3600

# Execution lock
EXECUTION_LOCK_TTL_SECONDS=300

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=optimus
POSTGRES_USER=optimus
POSTGRES_PASSWORD=optimus
DATABASE_URL=postgresql://optimus:optimus@localhost:5432/optimus

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# Queue (ARQ)
ARQ_REDIS_URL=redis://localhost:6379/1

# Providers
LLM_PROVIDER=mock
LLM_API_KEY=

# Telemetry
LOG_LEVEL=INFO

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Tooling
PROJECT_ROOT=/workspace/optmus
