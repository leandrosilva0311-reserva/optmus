APP_ENV=production
APP_NAME=optimus
DATABASE_URL=postgresql://optimus:<password>@<host>:5432/optimus
REDIS_URL=redis://<redis-host>:6379/0
REDIS_HOST=<redis-host>
REDIS_PORT=6379
DEFAULT_TENANT_API_KEY=<generate-a-strong-key>
AUTH_SESSION_TTL_SECONDS=3600
IDEMPOTENCY_WINDOW_MINUTES=30
RATE_LIMIT_PROJECT_PER_MINUTE=80
RATE_LIMIT_TOOL_PER_MINUTE=20
RATE_LIMIT_TENANT_PER_MINUTE=120
